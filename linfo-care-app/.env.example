# LinfoCare — app-scoped environment
# Copy this file to .env.local and fill in the values below.
# These are loaded by Vite during `npm run dev` / `npm run build` and
# baked into the client bundle (anything prefixed VITE_ is public).

# === Supabase (required) ===
# Anon key is public — Row Level Security protects data.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# === Vercel AI Gateway (no key needed here) ===
# The Doctora Lío chat endpoint (api/chat.js) routes through Vercel AI
# Gateway using the "openai/gpt-4o-mini" provider-prefixed model string.
# On Vercel runtime, VERCEL_OIDC_TOKEN is auto-injected into the function
# environment — no manual API key. For local `vercel dev`, run
# `vercel env pull` at the repo root to refresh the OIDC token.
